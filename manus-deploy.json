{
  "name": "verificador-contabil",
  "version": "1.0.0",
  "description": "Verificador de Natureza Contábil e Consolidador de Saldos Finais/Iniciais",
  "runtime": "node",
  "buildCommand": "pnpm install && pnpm run build",
  "startCommand": "NODE_ENV=production node dist/index.js",
  "port": 3000,
  "env": {
    "NODE_ENV": "production"
  },
  "files": [
    "client/",
    "server/",
    "shared/",
    "package.json",
    "pnpm-lock.yaml",
    "tsconfig.json",
    "tsconfig.node.json",
    "vite.config.ts",
    "components.json"
  ]
}
